{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article",
    "description": "Create your blog content"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text",
      "maxLength": 80
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "cover": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": [
        "images",
        "files",
        "videos"
      ]
    },
    "author": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::author.author",
      "inversedBy": "articles"
    },
    "blocks": {
      "type": "dynamiczone",
      "components": [
        "shared.media",
        "shared.quote",
        "shared.rich-text",
        "shared.slider"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::category.category"
    },
    "landmarks": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::landmark.landmark",
      "mappedBy": "article"
    },
    "StatusArticle": {
      "type": "enumeration",
      "default": "pending_review",
      "enum": [
        "draft",
        "pending_review",
        "published"
      ]
    },
    "governorate": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::governorate.governorate",
      "inversedBy": "articles"
    }
  }
}
